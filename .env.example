# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Hedera Testnet operator used to create demo transactions.
# Get these from the Hedera developer portal testnet account or faucet.
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ID=
HEDERA_OPERATOR_KEY=
HEDERA_OPERATOR_EVM_ADDRESS=

# Created by `pnpm demo:seed` once Hedera credentials are present.
HCS_AUDIT_TOPIC_ID=
HFS_MARKET_MANIFEST_FILE_ID=

# Full P0 credentials/integrations not required for the minimal scanner demo yet.
# Add these before claiming full PRD acceptance.
PROXY_REGISTRY_ADDRESS=
PROXY_REGISTRY_CONTRACT_ID=
PROOF_ESCROW_ADDRESS=
PROOF_ESCROW_CONTRACT_ID=
VERIFIER_REGISTRY_ADDRESS=
VERIFIER_REGISTRY_CONTRACT_ID=
HTS_INF_TOKEN_ID=
HTS_INF_TOKEN_EVM_ADDRESS=
DYNAMIC_ORGANIZATION_ID=
DYNAMIC_ENVIRONMENT_ID=
DYNAMIC_JWKS_URL=
DYNAMIC_CLIENT_ID=
DYNAMIC_WALLET_POLICY_ID=
X402_FACILITATOR_URL=
X402_NETWORK=hedera-testnet
X402_PAYMENT_ASSET=INF
ZKTLS_VERIFIER_URL=
ZKTLS_PROVIDER_POLICY_ID=
RECLAIM_APP_ID=
RECLAIM_APP_SECRET=
RECLAIM_PROVIDER_ID=
VERIFIER_SIGNER_ADDRESS=
VERIFIER_SIGNER_PRIVATE_KEY=
PROMPT_HISTORY_KEY_FILE=.local/prompt-history.key

# Seller node and registry publication.
SELLER_ID=local-seller
SELLER_DISPLAY_NAME=Local Seller Proxy
SELLER_HEDERA_ACCOUNT=
SELLER_EVM_ADDRESS=
SELLER_X402_ENDPOINT=http://localhost:8790/x402
SELLER_MODEL=gpt-4.1-mini
SELLER_PROVIDER=openai-compatible
SELLER_INPUT_PRICE_PER_MTOK_INF=0.05
SELLER_OUTPUT_PRICE_PER_MTOK_INF=0.12
SELLER_FIXED_FEE_INF=0.01
SELLER_MAX_BUDGET_INF=0.5
SELLER_MAX_INPUT_TOKENS=32000
SELLER_MAX_OUTPUT_TOKENS=4000
SELLER_PUBLISH_ON_CHAIN=true
SELLER_PORT=8790
LITELLM_BASE_URL=
LITELLM_API_KEY=
SELLER_REGISTRY_OFFER_ID=
SELLER_REGISTRY_TX_ID=
SELLER_REGISTRY_HASHSCAN_URL=

# Frontend
VITE_API_BASE_URL=http://localhost:8787

# Optional Cloudflare Pages deployment.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_PAGES_PROJECT=0-waist
